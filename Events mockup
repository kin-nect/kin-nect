<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ochre: #C8732A;
    --gold: #C8732A;
    --cream: #F5EDD8;
    --sage: #6B7C5E;
    --blush: #E8C9A0;
    --night: #0D0A06;
    --dark: #1A0E06;
    --border: rgba(200,115,42,0.15);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--night);
    color: var(--cream);
    font-family: 'Cormorant Garamond', serif;
    min-height: 100vh;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    padding: 1.2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: linear-gradient(to bottom, rgba(13,10,6,0.95) 0%, transparent 100%);
  }

  .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; letter-spacing: 0.15em; color: var(--ochre); text-decoration: none; }
  .nav-logo span { color: var(--cream); font-style: italic; font-weight: 400; }

  .nav-links { display: flex; gap: 2rem; list-style: none; font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; }
  .nav-links a { color: var(--blush); text-decoration: none; opacity: 0.6; transition: opacity 0.2s; }
  .nav-links a:hover, .nav-links a.active { opacity: 1; color: var(--ochre); }

  /* PAGE HEADER */
  .page-header {
    padding: 8rem 3rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ochre);
    opacity: 0.7;
    display: block;
    margin-bottom: 1rem;
  }

  .page-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    color: var(--cream);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .page-title em { color: var(--ochre); font-style: italic; }
  .page-desc { font-size: 1.05rem; color: var(--blush); opacity: 0.7; line-height: 1.8; max-width: 560px; }

  /* LAYOUT */
  .calendar-layout {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 3rem 6rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }

  /* FILTERS */
  .filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .filter-btn {
    font-family: 'Space Mono', monospace;
    font-size: 0.48rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: none;
    color: var(--blush);
    opacity: 0.6;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn.active, .filter-btn:hover { border-color: var(--ochre); color: var(--ochre); opacity: 1; }

  /* MONTH */
  .month-section { margin-bottom: 3rem; }

  .month-header {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ochre);
    opacity: 0.6;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid rgba(200,115,42,0.1);
    margin-bottom: 1rem;
  }

  /* EVENT ROW */
  .event-row {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 1rem;
    align-items: start;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(200,115,42,0.06);
    transition: background 0.2s;
    cursor: pointer;
    border-radius: 8px;
  }

  .event-row:hover { background: rgba(200,115,42,0.04); padding: 1rem 0.8rem; margin: 0 -0.8rem; }

  .event-date {
    text-align: center;
    flex-shrink: 0;
  }

  .event-day {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--cream);
    line-height: 1;
    display: block;
  }

  .event-mon {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--blush);
    opacity: 0.5;
  }

  .event-type-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ochre);
    opacity: 0.7;
    display: block;
    margin-bottom: 0.3rem;
  }

  .event-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--cream);
    line-height: 1.3;
    margin-bottom: 0.3rem;
  }

  .event-detail {
    font-size: 0.88rem;
    color: var(--blush);
    opacity: 0.6;
    line-height: 1.6;
  }

  .event-location {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.08em;
    color: var(--blush);
    opacity: 0.4;
    margin-top: 0.3rem;
    display: block;
  }

  .event-action { flex-shrink: 0; padding-top: 0.2rem; }

  .btn-ticket {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.45rem 0.9rem;
    background: var(--ochre);
    color: var(--night);
    border: none;
    border-radius: 20px;
    cursor: pointer;
    font-weight: 700;
    white-space: nowrap;
    transition: background 0.2s;
  }

  .btn-ticket:hover { background: #E8842A; }

  .btn-free {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.45rem 0.9rem;
    background: transparent;
    color: var(--ochre);
    border: 1px solid rgba(200,115,42,0.3);
    border-radius: 20px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .btn-free:hover { border-color: var(--ochre); }

  .event-price-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    color: var(--ochre);
    display: block;
    margin-bottom: 0.4rem;
    font-weight: 700;
  }

  /* FEATURED EVENT */
  .event-featured {
    background: rgba(200,115,42,0.04);
    border: 1px solid rgba(200,115,42,0.2);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
  }

  .event-featured::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--ochre), transparent);
  }

  /* SIDEBAR */
  .sidebar { position: sticky; top: 6rem; }

  .sidebar-card {
    background: rgba(26,14,6,0.6);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.2rem;
  }

  .sidebar-title {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 1rem;
  }

  .subscribe-input {
    width: 100%;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(200,115,42,0.15);
    border-radius: 8px;
    padding: 0.7rem 1rem;
    color: var(--cream);
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.95rem;
    outline: none;
    margin-bottom: 0.8rem;
  }

  .btn-subscribe {
    width: 100%;
    background: var(--ochre);
    color: var(--night);
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.7rem;
    border: none;
    border-radius: 25px;
    cursor: pointer;
    font-weight: 700;
  }

  .prefs { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }

  .pref-item { display: flex; align-items: center; gap: 0.6rem; font-size: 0.9rem; color: var(--blush); opacity: 0.75; cursor: pointer; }
  .pref-item input { accent-color: var(--ochre); }

  /* UPCOMING MINI */
  .mini-event {
    display: flex;
    gap: 0.8rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(200,115,42,0.06);
    align-items: center;
  }

  .mini-event:last-child { border-bottom: none; }

  .mini-date {
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    color: var(--ochre);
    min-width: 36px;
    text-align: center;
    opacity: 0.8;
  }

  .mini-name {
    font-size: 0.88rem;
    color: var(--blush);
    opacity: 0.75;
    line-height: 1.4;
  }

  /* SUBMIT */
  .submit-section {
    max-width: 1200px;
    margin: 0 auto 4rem;
    padding: 0 3rem;
  }

  .submit-box {
    background: rgba(200,115,42,0.03);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .submit-box h3 { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; color: var(--cream); margin-bottom: 0.4rem; }
  .submit-box p { font-size: 0.95rem; color: var(--blush); opacity: 0.6; line-height: 1.7; max-width: 480px; }

  .btn-submit-event {
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: var(--ochre);
    border: 1px solid rgba(200,115,42,0.35);
    border-radius: 25px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .btn-submit-event:hover { border-color: var(--ochre); background: rgba(200,115,42,0.06); }

  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 3rem;
    text-align: center;
  }

  .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 900; color: var(--ochre); letter-spacing: 0.15em; }
  .footer-logo span { color: var(--cream); font-style: italic; font-weight: 400; }

  @media (max-width: 900px) {
    .calendar-layout { grid-template-columns: 1fr; }
    .sidebar { position: static; }
    nav { padding: 1rem 1.5rem; }
    .nav-links { display: none; }
    .page-header, .calendar-layout, .submit-section { padding-left: 1.5rem; padding-right: 1.5rem; }
  }
</style>
</head>
